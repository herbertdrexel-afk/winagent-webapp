# ── Datenbank ─────────────────────────────────────────────────────────────────
# Lokal (docker-compose):
DB_PASSWORD=changeme

# Railway stellt DATABASE_URL automatisch bereit; fuer lokale Entwicklung:
# DATABASE_URL=postgresql://postgres:changeme@localhost/winagent

# ── Backend (Railway) ──────────────────────────────────────────────────────────
# Komma-getrennte Liste erlaubter Frontend-Origins (oder * fuer Entwicklung)
ALLOWED_ORIGINS=https://winagent.drexel.co.at,https://winagent-webapp.vercel.app

# ── Frontend (Vercel) ──────────────────────────────────────────────────────────
# URL des Railway-Backends (kein trailing slash)
VITE_API_URL=https://winagent-backend.up.railway.app
